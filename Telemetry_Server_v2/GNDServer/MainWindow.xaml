<Window x:Class="GNDServer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:s="http://schemas.abtsoftware.co.uk/scichart"
        Title="Telemetry Dashboard"
        Width="1280"
        Height="828" 
        Background="#1F2733"
        WindowStartupLocation="CenterScreen"
        >

    <Grid Background="#1F2733">
        <Grid.RowDefinitions>
            <RowDefinition Height="759*"/>
            <RowDefinition Height="5*"/>
        </Grid.RowDefinitions>
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled" Grid.RowSpan="2">
            <Grid Margin="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="160"/>
                    <RowDefinition Height="160"/>
                    <RowDefinition Height="160"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0"
                        Background="#273240"
                        BorderBrush="#374252"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="14"
                        Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Telemetry Dashboard"
                                       Foreground="White"
                                       FontSize="24"
                                       FontWeight="Bold"/>
                            <TextBlock Text="Realtime dashboard style motorsport"
                                       Foreground="#92A1B5"
                                       FontSize="12"
                                       Margin="0,4,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Top">
                            <Border Background="#222C38"
                                    BorderBrush="#374252"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="10,5"
                                    Margin="0,0,8,0">
                                <TextBlock Text="LIVE"
                                           Foreground="#7ED957"
                                           FontWeight="Bold"
                                           FontSize="11"/>
                            </Border>

                            <Border Background="#222C38"
                                    BorderBrush="#374252"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="10,5">
                                <TextBlock Text="Connected"
                                           Foreground="#D9E1EC"
                                           FontSize="11"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Velocity -->
                <Border Grid.Row="1"
                        Background="#273240"
                        BorderBrush="#374252"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="10"
                        Margin="0,0,0,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="2,0,2,8">
                            <TextBlock Text="RACE SPEED (KM/H)"
                                       Foreground="#D9E1EC"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       DockPanel.Dock="Left"/>
                            <StackPanel Orientation="Horizontal"
                                        DockPanel.Dock="Right">
                                <Ellipse Width="8" Height="8" Fill="#4FA3E3" Margin="0,2,6,0"/>
                                <TextBlock Text="Velocity"
                                           Foreground="#92A1B5"
                                           FontSize="11"/>
                            </StackPanel>
                        </DockPanel>

                        <s:SciChartSurface Grid.Row="1" Background="#25303D">
                            <s:SciChartSurface.XAxis>
                                <s:NumericAxis AutoRange="Always"
                                               DrawMajorBands="False"
                                               DrawMajorGridLines="True"
                                               DrawMinorGridLines="True"
                                               DrawLabels="False"
                                               DrawMajorTicks="False"
                                               DrawMinorTicks="False"/>
                            </s:SciChartSurface.XAxis>

                            <s:SciChartSurface.YAxis>
                                <s:NumericAxis AxisTitle="KM/H"
                                               AutoRange="Always"
                                               DrawMajorBands="False"
                                               DrawMajorGridLines="True"
                                               DrawMinorGridLines="True"/>
                            </s:SciChartSurface.YAxis>

                            <s:SciChartSurface.RenderableSeries>
                                <s:FastLineRenderableSeries DataSeries="{Binding VelocitySeries}"
                                                            Stroke="#4FA3E3"
                                                            StrokeThickness="2"/>
                            </s:SciChartSurface.RenderableSeries>

                            <s:SciChartSurface.ChartModifier>
                                <s:ModifierGroup>
                                    <s:MouseWheelZoomModifier/>
                                    <s:ZoomPanModifier ExecuteOn="MouseLeftButton"/>
                                    <s:ZoomExtentsModifier/>
                                    <s:RolloverModifier ShowTooltipOn="MouseHover"/>
                                </s:ModifierGroup>
                            </s:SciChartSurface.ChartModifier>
                        </s:SciChartSurface>
                    </Grid>
                </Border>

                <!-- RPM -->
                <Border Grid.Row="2"
                        Background="#273240"
                        BorderBrush="#374252"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="10"
                        Margin="0,0,0,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="2,0,2,8">
                            <TextBlock Text="ENGINE REVS (RPM)"
                                       Foreground="#D9E1EC"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       DockPanel.Dock="Left"/>
                            <StackPanel Orientation="Horizontal"
                                        DockPanel.Dock="Right">
                                <Ellipse Width="8" Height="8" Fill="#F26B2D" Margin="0,2,6,0"/>
                                <TextBlock Text="RPM"
                                           Foreground="#92A1B5"
                                           FontSize="11"/>
                            </StackPanel>
                        </DockPanel>

                        <s:SciChartSurface Grid.Row="1" Background="#25303D">
                            <s:SciChartSurface.XAxis>
                                <s:NumericAxis AutoRange="Always"
                                               DrawMajorBands="False"
                                               DrawMajorGridLines="True"
                                               DrawMinorGridLines="True"
                                               DrawLabels="False"
                                               DrawMajorTicks="False"
                                               DrawMinorTicks="False"/>
                            </s:SciChartSurface.XAxis>

                            <s:SciChartSurface.YAxis>
                                <s:NumericAxis AxisTitle="RPM"
                                               AutoRange="Always"
                                               DrawMajorBands="False"
                                               DrawMajorGridLines="True"
                                               DrawMinorGridLines="True"/>
                            </s:SciChartSurface.YAxis>

                            <s:SciChartSurface.RenderableSeries>
                                <s:FastLineRenderableSeries DataSeries="{Binding RPMSeries}"
                                                            Stroke="#F26B2D"
                                                            StrokeThickness="2"/>
                            </s:SciChartSurface.RenderableSeries>

                            <s:SciChartSurface.ChartModifier>
                                <s:ModifierGroup>
                                    <s:MouseWheelZoomModifier/>
                                    <s:ZoomPanModifier ExecuteOn="MouseLeftButton"/>
                                    <s:ZoomExtentsModifier/>
                                    <s:RolloverModifier ShowTooltipOn="MouseHover"/>
                                </s:ModifierGroup>
                            </s:SciChartSurface.ChartModifier>
                        </s:SciChartSurface>
                    </Grid>
                </Border>

                <!-- IMT -->
                <Border Grid.Row="3"
                Background="#273240"
                BorderBrush="#374252"
                BorderThickness="1"
                CornerRadius="8"
                Padding="10"
                Margin="0,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="2,0,2,8">
                            <TextBlock Text="INPUT / IMT"
                                       Foreground="#D9E1EC"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       DockPanel.Dock="Left"/>
                            <StackPanel Orientation="Horizontal"
                                        DockPanel.Dock="Right">
                                <Ellipse Width="8" Height="8" Fill="#7ED957" Margin="0,2,6,0"/>
                                <TextBlock Text="IMT"
                                           Foreground="#92A1B5"
                                           FontSize="11"/>
                            </StackPanel>
                        </DockPanel>

                        <s:SciChartSurface Background="#25303D" Height="145" VerticalAlignment="Top" Grid.Row="1">
                            <s:SciChartSurface.XAxis>
                                <s:NumericAxis AxisTitle="Sample Index"
                                               AutoRange="Always"
                                               DrawMajorBands="False"
                                               DrawMajorGridLines="True"
                                               DrawMinorGridLines="True"/>
                            </s:SciChartSurface.XAxis>

                            <s:SciChartSurface.YAxis>
                                <s:NumericAxis AxisTitle="IMT"
                                               AutoRange="Always"
                                               DrawMajorBands="False"
                                               DrawMajorGridLines="True"
                                               DrawMinorGridLines="True"/>
                            </s:SciChartSurface.YAxis>

                            <s:SciChartSurface.RenderableSeries>
                                <s:FastLineRenderableSeries DataSeries="{Binding IMTSeries}"
                                                            Stroke="#7ED957"
                                                            StrokeThickness="2"/>
                            </s:SciChartSurface.RenderableSeries>

                            <s:SciChartSurface.ChartModifier>
                                <s:ModifierGroup>
                                    <s:MouseWheelZoomModifier/>
                                    <s:ZoomPanModifier ExecuteOn="MouseLeftButton"/>
                                    <s:ZoomExtentsModifier/>
                                    <s:RolloverModifier ShowTooltipOn="MouseHover"/>
                                </s:ModifierGroup>
                            </s:SciChartSurface.ChartModifier>
                        </s:SciChartSurface>
                    </Grid>
                </Border>

                <!-- Bottom section -->
                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.05*"/>
                        <ColumnDefinition Width="1.15*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left cards -->
                    <Grid Grid.Column="0" Margin="0,0,12,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Row="0" Grid.Column="0"
                                Background="#273240"
                                BorderBrush="#374252"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,10,12,12">
                            <StackPanel>
                                <TextBlock Text="Current Velocity"
                                           Foreground="#92A1B5"
                                           FontSize="11"
                                           Margin="0,0,0,6"/>
                                <TextBlock Text="{Binding CurrentVelocity, StringFormat={}{0:F0}}"
                                           Foreground="White"
                                           FontSize="24"
                                           FontWeight="Bold"/>
                                <TextBlock Text="km/h"
                                           Foreground="#92A1B5"
                                           FontSize="12"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="0" Grid.Column="1"
                                Background="#273240"
                                BorderBrush="#374252"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,12,0,12">
                            <StackPanel>
                                <TextBlock Text="Current RPM"
                                           Foreground="#92A1B5"
                                           FontSize="11"
                                           Margin="0,0,0,6"/>
                                <TextBlock Text="{Binding CurrentRPM, StringFormat={}{0:F0}}"
                                           Foreground="White"
                                           FontSize="24"
                                           FontWeight="Bold"/>
                                <TextBlock Text="rev/min"
                                           Foreground="#92A1B5"
                                           FontSize="12"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1" Grid.Column="0"
                                Background="#273240"
                                BorderBrush="#374252"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,0,12,0">
                            <StackPanel>
                                <TextBlock Text="Current IMU"
                                           Foreground="#92A1B5"
                                           FontSize="11"
                                           Margin="0,0,0,6"/>
                                <TextBlock Text="{Binding CurrentIMT, StringFormat={}{0:F0}}"
                                           Foreground="White"
                                           FontSize="24"
                                           FontWeight="Bold"/>
                                <TextBlock Text="m/s2"
                                           Foreground="#92A1B5"
                                           FontSize="12"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1" Grid.Column="1"
                                Background="#273240"
                                BorderBrush="#374252"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12">
                            <StackPanel>
                                <TextBlock Text="System Status"
                                           Foreground="#92A1B5"
                                           FontSize="11"
                                           Margin="0,0,0,6"/>
                                <TextBlock Text="Receiving Port: 5000"
                                           Foreground="White"
                                           FontSize="18"
                                           FontWeight="SemiBold"/>
                                <!-- <ProgressBar Value="75"
                                             Height="8"
                                             Margin="0,12,0,0"
                                             Foreground="#4FA3E3"
                                             Background="#1F2733"/> -->
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Right section -->
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="200"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="#273240"
                                BorderBrush="#374252"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="10,12,10,0">
                            <Grid>
                                <TextBlock Text="Speed Gauge"
                                Foreground="#D9E1EC"
                                FontSize="11"
                                FontWeight="SemiBold"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Top"/>

                                <Viewbox Margin="20,20,20,20">
                                    <Grid Width="260" Height="260">
                                        <!-- vòng nền -->
                                        <Ellipse Width="180"
                                        Height="180"
                                        Stroke="#1A2430"
                                        StrokeThickness="12"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>

                                        <!-- cung màu ngoài -->
                                        <Path Stroke="#42D7FF"
                                        StrokeThickness="10"
                                        StrokeStartLineCap="Round"
                                        StrokeEndLineCap="Round"
                                        Data="M 55,170 A 90,90 0 1 1 205,170"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Top" Margin="0,10,0,0"/>

                                        <!-- tâm -->
                                        <Ellipse Width="18"
                                        Height="18"
                                        Fill="#3A4554"
                                        Stroke="#6E7B8C"
                                        StrokeThickness="2"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>

                                        <!-- kim -->
                                        <Line X1="130" Y1="130" X2="130" Y2="65"
                                        Stroke="#FF5A4F"
                                        StrokeThickness="4"
                                        StrokeStartLineCap="Round"
                                        StrokeEndLineCap="Round"
                                        RenderTransformOrigin="0.5,0.5">
                                            <Line.RenderTransform>
                                                <RotateTransform Angle="{Binding VelocityAngle}"/>
                                            </Line.RenderTransform>
                                        </Line>

                                        <!-- số lớn ở giữa -->
                                        <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Margin="0,70,0,0">
                                            <TextBlock Text="{Binding CurrentVelocity, StringFormat={}{0:F0}}"
                                            Foreground="White"
                                            FontSize="34"
                                            FontWeight="Bold"
                                            HorizontalAlignment="Center"/>
                                            <TextBlock Text="KM/H"
                                            Foreground="#42D7FF"
                                            FontSize="12"
                                            HorizontalAlignment="Center"/>
                                        </StackPanel>

                                        <!-- mốc trái -->
                                        <TextBlock Text="0"
                                        Foreground="#42D7FF"
                                        FontSize="11"
                                        Margin="42,180,0,0"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Top"/>

                                        <!-- mốc giữa -->
                                        <TextBlock Text="175"
                                        Foreground="#42D7FF"
                                        FontSize="11"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Top"
                                        Margin="0,20,0,0"/>

                                        <!-- mốc phải -->
                                        <TextBlock Text="350"
                                        Foreground="#42D7FF"
                                        FontSize="11"
                                        Margin="0,180,35,0"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"/>
                                    </Grid>
                                </Viewbox>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
