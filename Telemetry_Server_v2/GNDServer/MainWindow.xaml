<Window x:Class="GNDServer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:s="http://schemas.abtsoftware.co.uk/scichart"
        Title="Telemetry Dashboard"
        Height="900"
        Width="1400"
        Background="#1F2733"
        WindowStartupLocation="CenterScreen">

    <Grid Background="#1F2733">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="170"/>
                    <RowDefinition Height="170"/>
                    <RowDefinition Height="170"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0"
                        Background="#273240"
                        BorderBrush="#374252"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="14"
                        Margin="0,0,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Telemetry Dashboard"
                                       Foreground="White"
                                       FontSize="24"
                                       FontWeight="Bold"/>
                            <TextBlock Text="Realtime dashboard style motorsport"
                                       Foreground="#92A1B5"
                                       FontSize="12"
                                       Margin="0,4,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Top">
                            <Border Background="#222C38"
                                    BorderBrush="#374252"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="10,5"
                                    Margin="0,0,8,0">
                                <TextBlock Text="LIVE"
                                           Foreground="#7ED957"
                                           FontWeight="Bold"
                                           FontSize="11"/>
                            </Border>

                            <Border Background="#222C38"
                                    BorderBrush="#374252"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="10,5">
                                <TextBlock Text="Connected"
                                           Foreground="#D9E1EC"
                                           FontSize="11"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Velocity -->
                <Border Grid.Row="1"
                        Background="#273240"
                        BorderBrush="#374252"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="10"
                        Margin="0,0,0,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="2,0,2,8">
                            <TextBlock Text="RACE SPEED (KM/H)"
                                       Foreground="#D9E1EC"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       DockPanel.Dock="Left"/>
                            <StackPanel Orientation="Horizontal"
                                        DockPanel.Dock="Right">
                                <Ellipse Width="8" Height="8" Fill="#4FA3E3" Margin="0,2,6,0"/>
                                <TextBlock Text="Velocity"
                                           Foreground="#92A1B5"
                                           FontSize="11"/>
                            </StackPanel>
                        </DockPanel>

                        <s:SciChartSurface Grid.Row="1" Background="#25303D">
                            <s:SciChartSurface.XAxis>
                                <s:NumericAxis AutoRange="Always"
                                               DrawMajorBands="False"
                                               DrawMajorGridLines="True"
                                               DrawMinorGridLines="True"
                                               DrawLabels="False"
                                               DrawMajorTicks="False"
                                               DrawMinorTicks="False"/>
                            </s:SciChartSurface.XAxis>

                            <s:SciChartSurface.YAxis>
                                <s:NumericAxis AxisTitle="KM/H"
                                               AutoRange="Always"
                                               DrawMajorBands="False"
                                               DrawMajorGridLines="True"
                                               DrawMinorGridLines="True"/>
                            </s:SciChartSurface.YAxis>

                            <s:SciChartSurface.RenderableSeries>
                                <s:FastLineRenderableSeries DataSeries="{Binding VelocitySeries}"
                                                            Stroke="#4FA3E3"
                                                            StrokeThickness="2"/>
                            </s:SciChartSurface.RenderableSeries>

                            <s:SciChartSurface.ChartModifier>
                                <s:ModifierGroup>
                                    <s:MouseWheelZoomModifier/>
                                    <s:ZoomPanModifier ExecuteOn="MouseLeftButton"/>
                                    <s:ZoomExtentsModifier/>
                                    <s:RolloverModifier ShowTooltipOn="MouseHover"/>
                                </s:ModifierGroup>
                            </s:SciChartSurface.ChartModifier>
                        </s:SciChartSurface>
                    </Grid>
                </Border>

                <!-- RPM -->
                <Border Grid.Row="2"
                        Background="#273240"
                        BorderBrush="#374252"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="10"
                        Margin="0,0,0,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="2,0,2,8">
                            <TextBlock Text="ENGINE REVS (RPM)"
                                       Foreground="#D9E1EC"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       DockPanel.Dock="Left"/>
                            <StackPanel Orientation="Horizontal"
                                        DockPanel.Dock="Right">
                                <Ellipse Width="8" Height="8" Fill="#F26B2D" Margin="0,2,6,0"/>
                                <TextBlock Text="RPM"
                                           Foreground="#92A1B5"
                                           FontSize="11"/>
                            </StackPanel>
                        </DockPanel>

                        <s:SciChartSurface Grid.Row="1" Background="#25303D">
                            <s:SciChartSurface.XAxis>
                                <s:NumericAxis AutoRange="Always"
                                               DrawMajorBands="False"
                                               DrawMajorGridLines="True"
                                               DrawMinorGridLines="True"
                                               DrawLabels="False"
                                               DrawMajorTicks="False"
                                               DrawMinorTicks="False"/>
                            </s:SciChartSurface.XAxis>

                            <s:SciChartSurface.YAxis>
                                <s:NumericAxis AxisTitle="RPM"
                                               AutoRange="Always"
                                               DrawMajorBands="False"
                                               DrawMajorGridLines="True"
                                               DrawMinorGridLines="True"/>
                            </s:SciChartSurface.YAxis>

                            <s:SciChartSurface.RenderableSeries>
                                <s:FastLineRenderableSeries DataSeries="{Binding RPMSeries}"
                                                            Stroke="#F26B2D"
                                                            StrokeThickness="2"/>
                            </s:SciChartSurface.RenderableSeries>

                            <s:SciChartSurface.ChartModifier>
                                <s:ModifierGroup>
                                    <s:MouseWheelZoomModifier/>
                                    <s:ZoomPanModifier ExecuteOn="MouseLeftButton"/>
                                    <s:ZoomExtentsModifier/>
                                    <s:RolloverModifier ShowTooltipOn="MouseHover"/>
                                </s:ModifierGroup>
                            </s:SciChartSurface.ChartModifier>
                        </s:SciChartSurface>
                    </Grid>
                </Border>

                <!-- IMT -->
                <Border Grid.Row="3"
                        Background="#273240"
                        BorderBrush="#374252"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="10"
                        Margin="0,0,0,370" Grid.RowSpan="2">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="2,0,2,8">
                            <TextBlock Text="INPUT / IMT"
                                       Foreground="#D9E1EC"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       DockPanel.Dock="Left"/>
                            <StackPanel Orientation="Horizontal"
                                        DockPanel.Dock="Right">
                                <Ellipse Width="8" Height="8" Fill="#7ED957" Margin="0,2,6,0"/>
                                <TextBlock Text="IMT"
                                           Foreground="#92A1B5"
                                           FontSize="11"/>
                            </StackPanel>
                        </DockPanel>

                        <s:SciChartSurface Grid.Row="1" Background="#25303D" Height="145" VerticalAlignment="Top">
                            <s:SciChartSurface.XAxis>
                                <s:NumericAxis AxisTitle="Sample Index"
                                               AutoRange="Always"
                                               DrawMajorBands="False"
                                               DrawMajorGridLines="True"
                                               DrawMinorGridLines="True"/>
                            </s:SciChartSurface.XAxis>

                            <s:SciChartSurface.YAxis>
                                <s:NumericAxis AxisTitle="IMT"
                                               AutoRange="Always"
                                               DrawMajorBands="False"
                                               DrawMajorGridLines="True"
                                               DrawMinorGridLines="True"/>
                            </s:SciChartSurface.YAxis>

                            <s:SciChartSurface.RenderableSeries>
                                <s:FastLineRenderableSeries DataSeries="{Binding IMTSeries}"
                                                            Stroke="#7ED957"
                                                            StrokeThickness="2"/>
                            </s:SciChartSurface.RenderableSeries>

                            <s:SciChartSurface.ChartModifier>
                                <s:ModifierGroup>
                                    <s:MouseWheelZoomModifier/>
                                    <s:ZoomPanModifier ExecuteOn="MouseLeftButton"/>
                                    <s:ZoomExtentsModifier/>
                                    <s:RolloverModifier ShowTooltipOn="MouseHover"/>
                                </s:ModifierGroup>
                            </s:SciChartSurface.ChartModifier>
                        </s:SciChartSurface>
                    </Grid>
                </Border>

                <!-- Bottom section -->
                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.05*"/>
                        <ColumnDefinition Width="1.15*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left cards -->
                    <Grid Grid.Column="0" Margin="0,-23,12,23">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Row="0" Grid.Column="0"
                                Background="#273240"
                                BorderBrush="#374252"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,47,12,12">
                            <StackPanel>
                                <TextBlock Text="Current Velocity"
                                           Foreground="#92A1B5"
                                           FontSize="11"
                                           Margin="0,0,0,6"/>
                                <TextBlock Text="--"
                                           Foreground="White"
                                           FontSize="24"
                                           FontWeight="Bold"/>
                                <TextBlock Text="km/h"
                                           Foreground="#92A1B5"
                                           FontSize="12"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="0"
                                Background="#273240"
                                BorderBrush="#374252"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="317,47,0,12" Grid.ColumnSpan="2">
                            <StackPanel>
                                <TextBlock Text="Current RPM"
                                           Foreground="#92A1B5"
                                           FontSize="11"
                                           Margin="0,0,0,6"/>
                                <TextBlock Text="--"
                                           Foreground="White"
                                           FontSize="24"
                                           FontWeight="Bold"/>
                                <TextBlock Text="rev/min"
                                           Foreground="#92A1B5"
                                           FontSize="12"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1" Grid.Column="0"
                                Background="#273240"
                                BorderBrush="#374252"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,0,12,0">
                            <StackPanel>
                                <TextBlock Text="Current IMT"
                                           Foreground="#92A1B5"
                                           FontSize="11"
                                           Margin="0,0,0,6"/>
                                <TextBlock Text="--"
                                           Foreground="White"
                                           FontSize="24"
                                           FontWeight="Bold"/>
                                <TextBlock Text="input value"
                                           Foreground="#92A1B5"
                                           FontSize="12"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1" Grid.Column="1"
                                Background="#273240"
                                BorderBrush="#374252"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12">
                            <StackPanel>
                                <TextBlock Text="System Status"
                                           Foreground="#92A1B5"
                                           FontSize="11"
                                           Margin="0,0,0,6"/>
                                <TextBlock Text="Receiving UDP"
                                           Foreground="White"
                                           FontSize="18"
                                           FontWeight="SemiBold"/>
                                <ProgressBar Value="75"
                                             Height="8"
                                             Margin="0,12,0,0"
                                             Foreground="#4FA3E3"
                                             Background="#1F2733"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Right section -->
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="300"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="#273240"
                                BorderBrush="#374252"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="10,24,10,72">
                            <Grid>
                                <TextBlock Text="Track Map"
                                           Foreground="#D9E1EC"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Top"/>

                                <Viewbox Margin="20,20,20,20">
                                    <Grid Width="260" Height="260">
                                        <Path Stroke="#BFC4C9"
                                              StrokeThickness="4"
                                              Stretch="Uniform"
                                              Data="M 118,18
                                                    C 165,15 206,42 212,78
                                                    C 217,110 194,125 199,153
                                                    C 206,189 244,193 250,228
                                                    C 257,270 231,304 198,314
                                                    C 173,322 162,296 142,300
                                                    C 118,305 109,339 86,336
                                                    C 61,332 60,288 41,270
                                                    C 21,251 10,239 14,208
                                                    C 19,173 58,159 56,130
                                                    C 54,101 25,84 33,57
                                                    C 41,31 78,18 118,18" />

                                        <Ellipse Width="14"
                                                 Height="14"
                                                 Fill="#F2D94E"
                                                 Stroke="#DDCA3A"
                                                 StrokeThickness="2"
                                                 HorizontalAlignment="Left"
                                                 VerticalAlignment="Top"
                                                 Margin="58,120,0,0"/>
                                    </Grid>
                                </Viewbox>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1"
                                Background="#273240"
                                BorderBrush="#374252"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Packet Source"
                                               Foreground="#92A1B5"
                                               FontSize="11"
                                               Margin="0,0,0,6"/>
                                    <TextBlock Text="UDP :5000"
                                               Foreground="White"
                                               FontSize="18"
                                               FontWeight="SemiBold"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Theme"
                                               Foreground="#92A1B5"
                                               FontSize="11"
                                               Margin="0,0,0,6"/>
                                    <TextBlock Text="Dark Motorsport"
                                               Foreground="White"
                                               FontSize="18"
                                               FontWeight="SemiBold"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Runtime"
                                               Foreground="#92A1B5"
                                               FontSize="11"
                                               Margin="0,0,0,6"/>
                                    <TextBlock Text="SciChart + WPF"
                                               Foreground="White"
                                               FontSize="18"
                                               FontWeight="SemiBold"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
