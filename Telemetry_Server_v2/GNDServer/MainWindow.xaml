<Window x:Class="GNDServer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:s="http://schemas.abtsoftware.co.uk/scichart"
        Title="Telemetry Monitor"
        Height="800"
        Width="1400"
        Background="#EEF2F7">

    <Window.Resources>
        <Style x:Key="ChartSurfaceStyle" TargetType="s:SciChartSurface">
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style x:Key="YAxisStyle" TargetType="s:NumericAxis">
            <Setter Property="AutoRange" Value="Always"/>
            <Setter Property="DrawMajorBands" Value="False"/>
            <Setter Property="DrawMajorGridLines" Value="True"/>
            <Setter Property="DrawMinorGridLines" Value="False"/>
            <Setter Property="MaxAutoTicks" Value="5"/>
            <Setter Property="MinorsPerMajor" Value="1"/>
        </Style>

        <Style x:Key="TopXAxisStyle" TargetType="s:NumericAxis">
            <Setter Property="AutoRange" Value="Always"/>
            <Setter Property="DrawLabels" Value="False"/>
            <Setter Property="DrawMajorTicks" Value="False"/>
            <Setter Property="DrawMinorTicks" Value="False"/>
            <Setter Property="DrawMajorBands" Value="False"/>
            <Setter Property="DrawMajorGridLines" Value="True"/>
            <Setter Property="DrawMinorGridLines" Value="False"/>
            <Setter Property="MaxAutoTicks" Value="6"/>
            <Setter Property="MinorsPerMajor" Value="1"/>
        </Style>

        <Style x:Key="BottomXAxisStyle" TargetType="s:NumericAxis">
            <Setter Property="AutoRange" Value="Always"/>
            <Setter Property="AxisTitle" Value="Sample Index"/>
            <Setter Property="DrawMajorBands" Value="False"/>
            <Setter Property="DrawMajorGridLines" Value="True"/>
            <Setter Property="DrawMinorGridLines" Value="False"/>
            <Setter Property="MaxAutoTicks" Value="6"/>
            <Setter Property="MinorsPerMajor" Value="1"/>
        </Style>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D9E1EA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="220"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT: Charts -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                <TextBlock Text="Telemetry Monitor"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="#1E293B"/>
                <TextBlock Text="RPM, Velocity, and IMT Over Time"
                           FontSize="14"
                           Foreground="#64748B"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <!-- IMT -->
            <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="IMT"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#475569"
                               Margin="4,0,0,6"/>

                    <s:SciChartSurface Grid.Row="1"
                                       Style="{StaticResource ChartSurfaceStyle}">
                        <s:SciChartSurface.XAxis>
                            <s:NumericAxis Style="{StaticResource TopXAxisStyle}"/>
                        </s:SciChartSurface.XAxis>

                        <s:SciChartSurface.YAxis>
                            <s:NumericAxis Style="{StaticResource YAxisStyle}"/>
                        </s:SciChartSurface.YAxis>

                        <s:SciChartSurface.RenderableSeries>
                            <s:FastLineRenderableSeries DataSeries="{Binding IMTSeries}"
                                                        Stroke="Red"
                                                        StrokeThickness="2"/>
                        </s:SciChartSurface.RenderableSeries>

                        <s:SciChartSurface.ChartModifier>
                            <s:ModifierGroup>
                                <s:MouseWheelZoomModifier/>
                                <s:ZoomPanModifier ExecuteOn="MouseLeftButton"/>
                                <s:ZoomExtentsModifier/>
                                <s:RolloverModifier ShowTooltipOn="MouseHover"/>
                            </s:ModifierGroup>
                        </s:SciChartSurface.ChartModifier>
                    </s:SciChartSurface>
                </Grid>
            </Border>

            <!-- Velocity -->
            <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Velocity"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#475569"
                               Margin="4,0,0,6"/>

                    <s:SciChartSurface Grid.Row="1"
                                       Style="{StaticResource ChartSurfaceStyle}">
                        <s:SciChartSurface.XAxis>
                            <s:NumericAxis Style="{StaticResource TopXAxisStyle}"/>
                        </s:SciChartSurface.XAxis>

                        <s:SciChartSurface.YAxis>
                            <s:NumericAxis Style="{StaticResource YAxisStyle}"/>
                        </s:SciChartSurface.YAxis>

                        <s:SciChartSurface.RenderableSeries>
                            <s:FastLineRenderableSeries DataSeries="{Binding VelocitySeries}"
                                                        Stroke="Blue"
                                                        StrokeThickness="2"/>
                        </s:SciChartSurface.RenderableSeries>

                        <s:SciChartSurface.ChartModifier>
                            <s:ModifierGroup>
                                <s:MouseWheelZoomModifier/>
                                <s:ZoomPanModifier ExecuteOn="MouseLeftButton"/>
                                <s:ZoomExtentsModifier/>
                                <s:RolloverModifier ShowTooltipOn="MouseHover"/>
                            </s:ModifierGroup>
                        </s:SciChartSurface.ChartModifier>
                    </s:SciChartSurface>
                </Grid>
            </Border>

            <!-- RPM -->
            <Border Grid.Row="3" Style="{StaticResource CardBorderStyle}" Margin="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="RPM"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#475569"
                               Margin="4,0,0,6"/>

                    <s:SciChartSurface Grid.Row="1"
                                       Style="{StaticResource ChartSurfaceStyle}">
                        <s:SciChartSurface.XAxis>
                            <s:NumericAxis Style="{StaticResource BottomXAxisStyle}"/>
                        </s:SciChartSurface.XAxis>

                        <s:SciChartSurface.YAxis>
                            <s:NumericAxis Style="{StaticResource YAxisStyle}"/>
                        </s:SciChartSurface.YAxis>

                        <s:SciChartSurface.RenderableSeries>
                            <s:FastLineRenderableSeries DataSeries="{Binding RPMSeries}"
                                                        Stroke="LimeGreen"
                                                        StrokeThickness="2"/>
                        </s:SciChartSurface.RenderableSeries>

                        <s:SciChartSurface.ChartModifier>
                            <s:ModifierGroup>
                                <s:MouseWheelZoomModifier/>
                                <s:ZoomPanModifier ExecuteOn="MouseLeftButton"/>
                                <s:ZoomExtentsModifier/>
                                <s:RolloverModifier ShowTooltipOn="MouseHover"/>
                            </s:ModifierGroup>
                        </s:SciChartSurface.ChartModifier>
                    </s:SciChartSurface>
                </Grid>
            </Border>
        </Grid>

        <!-- RIGHT: Legend -->
        <Border Grid.Column="1"
                Background="White"
                BorderBrush="#D9E1EA"
                BorderThickness="1"
                CornerRadius="8"
                Padding="14"
                Margin="16,56,0,0"
                VerticalAlignment="Top">
            <StackPanel>
                <TextBlock Text="Legend"
                           FontSize="15"
                           FontWeight="Bold"
                           Foreground="#1E293B"
                           Margin="0,0,0,10"/>

                <StackPanel Orientation="Horizontal" Margin="0,6,0,6">
                    <Ellipse Width="10" Height="10" Fill="LimeGreen" Margin="0,0,8,0"/>
                    <TextBlock Text="RPM" VerticalAlignment="Center" Foreground="#334155"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,6,0,6">
                    <Ellipse Width="10" Height="10" Fill="Blue" Margin="0,0,8,0"/>
                    <TextBlock Text="Velocity" VerticalAlignment="Center" Foreground="#334155"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,6,0,6">
                    <Ellipse Width="10" Height="10" Fill="Red" Margin="0,0,8,0"/>
                    <TextBlock Text="IMT" VerticalAlignment="Center" Foreground="#334155"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>