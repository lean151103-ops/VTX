<Window x:Class="GNDServer_v2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:s="http://schemas.abtsoftware.co.uk/scichart"
        Title="Telemetry Dashboard"
        Width="1800"
        Height="900"
        Background="#1F2733"
        WindowStartupLocation="CenterScreen">

    <Grid Background="#1F2733">
        <TabControl Margin="0"
                    Background="#273240"
                    Foreground="White"
                    BorderBrush="#374252"
                    BorderThickness="0">

            <!-- TAB 1 -->
            <TabItem Header="Realtime Summary">
                <Grid Background="#1F2733">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- TITLE BLOCK -->
                    <Border Grid.Row="0"
                            Margin="0,0,0,0"
                            Padding="0"
                            Background="#1F2733"
                            BorderThickness="0">
                        <TextBlock Text="Real Time Telemetry"
                                   FontSize="20"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Margin="0,0,0,0"/>
                    </Border>

                    <!-- DATA BLOCK -->
                    <ScrollViewer Grid.Row="1"
                                  Margin="0,5,0,0"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <Grid Background="#1F2733">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0"
                                    Background="#273240"
                                    Margin="5,0,10,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="2*" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0"
                                        Margin ="0,0,0,0"
                                        Background="#3B4758">
                                </Border>

                                <Border Grid.Row="1"
                                Margin="0,5,0,0"
                                Background="#1F2733">
                                    <DockPanel LastChildFill="True">

                                        <Border DockPanel.Dock="Top"
                                                Height="30"
                                                Margin="0,0,0,5"
                                                Background="#2E3A4A">
                                            <TextBlock  Text="Laptime"
                                                        Foreground="White"
                                                        FontSize="15"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        TextAlignment="Center"/>
                                        </Border>

                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            
                                            <Grid Grid.Row="0"
                                                  Background="#1B2430">
                                                <TextBlock  Text="{Binding LapTimeText}"
                                                            Foreground="#D6DEE8"
                                                            FontSize="30"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"/>
                                            </Grid>

                                            <Border Grid.Row="1"
                                                    Background="#1B2430"
                                                    BorderBrush="#2F3B4A"
                                                    BorderThickness="1,1,0,0">
                                                <s:SciChartSurface  x:Name="LapTrackChart"
                                                                    Background="#1B2430"
                                                                    Padding="0"
                                                                    BorderThickness="0">
                                                    <s:SciChartSurface.XAxis>
                                                        <s:NumericAxis AutoRange="Never"
                                                                       VisibleRange="0,4500"
                                                                       AxisTitle="Distance along Track"
                                                                       TextFormatting="#,##0 'm'"
                                                                       DrawMajorBands="False"
                                                                       DrawMinorGridLines="False"
                                                                       DrawMajorGridLines="True"
                                                                       DrawMinorTicks="False"
                                                                       DrawMajorTicks="True"/>
                                                    </s:SciChartSurface.XAxis>
                                                    <s:SciChartSurface.YAxis>
                                                        <s:NumericAxis AutoRange="Never"
                                                                       VisibleRange="-0.2,0.2"
                                                                       DrawLabels="False"
                                                                       DrawMajorBands="False"
                                                                       DrawMinorGridLines="False"
                                                                       DrawMajorGridLines="False"
                                                                       DrawMinorTicks="False"
                                                                       DrawMajorTicks="False"/>
                                                    </s:SciChartSurface.YAxis>

                                                    <!-- <s:FastLineRenderableSeries x:Name="TrackBaseSeries"
                                                                                Stroke="#AEB7C2"
                                                                                StrokeThickness="2"/> -->
                                                    <!-- Tracking car position -->
                                                    <!-- <s:XyScatterRenderableSeries x:Name="CarMarkerSeries">
                                                        <s:XyScatterRenderableSeries.PointMarker>
                                                            <s:EllipsePointMarker Width="10"
                                                                                  Height="10"
                                                                                  Fill="#6FA8DC"
                                                                                  Stroke="#6FA8DC"/>
                                                        </s:XyScatterRenderableSeries.PointMarker> 
                                                    </s:XyScatterRenderableSeries> -->
                                                </s:SciChartSurface>
                                            </Border>
                                        </Grid>
                                    </DockPanel>
                                </Border>
                            </Grid>

                            <Grid Grid.Column="1"
                                    Background="#273240"
                                    Margin="5,0,10,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0"
                                        Margin ="0,0,0,0"
                                        Background="#354152">
                                </Border>

                                <Border Grid.Row="1"
                                        Margin="0,5,0,0"
                                        Background="#2E3A4A">
                                    <UniformGrid Rows="3">
                                        <Border Margin="0,0,0,5"
                                                Background="#354152"/>
                                        <Border Background="#3B4758"/>
                                    </UniformGrid>
                                </Border>

                                <Border Grid.Row="2"
                                        Margin="0,5,0,0"
                                        Background="#3B4758">
                                </Border>
                            </Grid>

                            <Grid Grid.Column="2"
                                    Background="#273240"
                                    Margin="5,0,10,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="2*" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0"
                                        Margin ="0,0,0,0"
                                        Background="#2E3A4A">
                                </Border>

                                <Border Grid.Row="1"
                                        Margin="0,5,0,0"
                                        Background="#273240">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- CỘT 1 -->
                                        <Border Grid.Column="0"
                                                Margin="0,0,5,0"
                                                Background="#1F2733">

                                            <DockPanel LastChildFill="True">
                                                <Border DockPanel.Dock="Top"
                                                        Height="30"
                                                        Margin="0,0,0,5"
                                                        Background="#2E3A4A">
                                                    <TextBlock Text="Throttle"
                                                               Foreground="White"
                                                               FontSize="15"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               TextAlignment="Center"/>
                                                </Border>

                                                <s:SciChartSurface x:Name="ThrottleChart"
                                                                   Background="#1B2430"
                                                                   Padding="0"
                                                                   BorderThickness="0">
                                                    <s:SciChartSurface.XAxis>
                                                        <s:NumericAxis AutoRange="Never"
                                                                       DrawMajorGridLines="False"
                                                                       DrawMinorGridLines="False"
                                                                       DrawMajorBands="False"
                                                                       DrawLabels="False"
                                                                       DrawMinorTicks="False"
                                                                       DrawMajorTicks="False"
                                                                       VisibleRange="-0.5,1.5"/>
                                                    </s:SciChartSurface.XAxis>
                                                    <s:SciChartSurface.YAxis>
                                                        <s:NumericAxis AutoRange="Never"
                                                                       VisibleRange="0,1"
                                                                       TextFormatting="0.00"
                                                                       DrawMajorBands="False"
                                                                       DrawMinorGridLines="False"
                                                                       DrawMajorGridLines="False"
                                                                       DrawMinorTicks="False"
                                                                       DrawMajorTicks="True"/>
                                                    </s:SciChartSurface.YAxis>

                                                    <!-- <s:FastColumnRenderableSeries x:Name="ThrottleSeries"
                                                                                  DataPointWidth="0.55"
                                                                                  Fill="#6BC56B"
                                                                                  StrokeThickness="0"/> -->
                                                </s:SciChartSurface>
                                            </DockPanel>
                                        </Border>

                                        <!-- CỘT 2 -->
                                        <Border Grid.Column="1"
                                                Margin="0,0,5,0"
                                                Background="#1F2733">
                                            <DockPanel LastChildFill="True">
                                                <Border DockPanel.Dock="Top"
                                                        Height="30"
                                                        Margin="0,0,0,5"
                                                        Background="#2E3A4A">
                                                    <TextBlock Text="Brake"
                                                               Foreground="White"
                                                               FontSize="15"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               TextAlignment="Center"/>
                                                </Border>

                                                <s:SciChartSurface x:Name="BrakeChart"
                                                                   Background="#1B2430"
                                                                   Padding="0"
                                                                   BorderThickness="0">
                                                    <s:SciChartSurface.XAxis>
                                                        <s:NumericAxis AutoRange="Never"
                                                                       DrawMajorGridLines="False"
                                                                       DrawMinorGridLines="False"
                                                                       DrawMajorBands="False"
                                                                       DrawLabels="False"
                                                                       DrawMinorTicks="False"
                                                                       DrawMajorTicks="False"
                                                                       VisibleRange="-0.5,1.5"/>
                                                    </s:SciChartSurface.XAxis>
                                                    <s:SciChartSurface.YAxis>
                                                        <s:NumericAxis AutoRange="Never"
                                                                       VisibleRange="0,1"
                                                                       TextFormatting="0.00"
                                                                       DrawMajorBands="False"
                                                                       DrawMinorGridLines="False"
                                                                       DrawMajorGridLines="False"
                                                                       DrawMinorTicks="False"
                                                                       DrawMajorTicks="True"/>
                                                    </s:SciChartSurface.YAxis>
                                                    <!-- <s:FastColumnRenderableSeries x:Name="BrakeSeries"
                                                                                  DataPointWidth="0.55"
                                                                                  Fill="#D9534F"
                                                                                  StrokeThickness="0"/> -->
                                                </s:SciChartSurface>
                                            </DockPanel>
                                        </Border>

                                        <!-- CỘT 3 -->
                                        <Border Grid.Column="2"
                                                Margin="0,0,0,0"
                                                Background="#1F2733">

                                            <DockPanel LastChildFill="True">
                                                <Border DockPanel.Dock="Top"
                                                        Height="30"
                                                        Margin="0,0,0,5"
                                                        Background="#2E3A4A">
                                                    <TextBlock Text="Fuel Tank"
                                                               Foreground="White"
                                                               FontSize="15"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               TextAlignment="Center"/>
                                                </Border>

                                                <Grid Background="#1B2430">
                                                    <s:SciChartSurface  x:Name="FuelChart"
                                                                        Margin="0"
                                                                        Background="#1B2430"
                                                                        Padding="0"
                                                                        BorderThickness="0">
                                                        <s:SciChartSurface.XAxis>
                                                            <s:NumericAxis AutoRange="Never"
                                                                           DrawMajorGridLines="False"
                                                                           DrawMinorGridLines="False"
                                                                           DrawMajorBands="False"
                                                                           DrawLabels="False"
                                                                           DrawMinorTicks="False"
                                                                           DrawMajorTicks="False"
                                                                           VisibleRange="-0.5,1.5"/>
                                                        </s:SciChartSurface.XAxis>
                                                        <s:SciChartSurface.YAxis>
                                                            <s:NumericAxis  AutoRange="Never"
                                                                            VisibleRange="0,10"
                                                                            TextFormatting="0.00 L"
                                                                            DrawMajorBands="False"
                                                                            DrawMinorGridLines="False"
                                                                            DrawMajorGridLines="False"
                                                                            DrawMinorTicks="False"
                                                                            DrawMajorTicks="True"/>
                                                        </s:SciChartSurface.YAxis>
                                                        <!-- <s:FastColumnRenderableSeries x:Name="FuelSeries"
                                                                                      DataPointWidth="0.9"
                                                                                      Fill="#E8D88D"
                                                                                      StrokeThickness="0"/> -->
                                                    </s:SciChartSurface>
                                                </Grid>

                                            </DockPanel>
                                        </Border>

                                    </Grid>
                                </Border>
                            </Grid>

                        </Grid>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- TAB 2 -->
            <TabItem Header="Race Summary Graph">
                <Grid Background="#1F2733">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Title -->
                        <RowDefinition Height="*"/>
                        <!-- Data -->
                    </Grid.RowDefinitions>

                    <!-- TITLE BLOCK -->
                    <Border Grid.Row="0"
                            Margin="0,0,0,0"
                            Padding="0"
                            Background="#273240"
                            BorderBrush="#374252"
                            BorderThickness="1">
                        <TextBlock Text="Race Summary Graph"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="White"/>
                    </Border>

                    <!-- DATA BLOCK -->
                    <ScrollViewer Grid.Row="1"
                                  Margin="10"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <Grid Background="#273240">
                            <!-- BUILD BLOCK TAB 2 Ở ĐÂY -->
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>