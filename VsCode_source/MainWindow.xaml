<Window x:Class="GNDServer2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:s="http://schemas.abtsoftware.co.uk/scichart"
        Title="Telemetry Dashboard"
        Width="1800"
        Height="900"
        Background="#1F2733"
        WindowStartupLocation="CenterScreen">

    <Grid Background="#1F2733">

        <TabControl Margin="0"
                    Background="#273240"
                    Foreground="White"
                    BorderBrush="#374252"
                    BorderThickness="0">

            <!-- TAB 1 -->
            <TabItem Header="Realtime Summary">
                <Grid Background="#1F2733">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- TITLE BLOCK -->
                    <Border Grid.Row="0"
                            Margin="0,0,0,0"
                            Padding="0"
                            Background="#1F2733"
                            BorderThickness="0">
                        <TextBlock Text="Real Time Telemetry"
                                   FontSize="20"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Margin="0,0,0,0"/>
                    </Border>

                    <!-- DATA BLOCK -->
                    <ScrollViewer Grid.Row="1"
                                  Margin="0,5,0,0"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <Grid Background="#1F2733">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0"
                                    Background="#273240"
                                    Margin="5,0,10,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="2*" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0"
                                        Margin ="0,0,0,0"
                                        Background="#3B4758">
                                </Border>

                                <Border Grid.Row="1"
                                Margin="0,5,0,0"
                                Background="#1F2733">
                                    <DockPanel LastChildFill="True">

                                        <Border DockPanel.Dock="Top"
                                                Height="30"
                                                Margin="0,0,0,5"
                                                Background="#2E3A4A">
                                            <TextBlock  Text="Laptime"
                                                        Foreground="White"
                                                        FontSize="15"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        TextAlignment="Center"/>
                                        </Border>

                                        <UniformGrid Rows="2">
                                            <Border Margin="0,0,0,5"
                                                    Background="#354152"/>
                                            <Border Background="#3B4758"/>
                                        </UniformGrid>

                                    </DockPanel>
                                </Border>
                            </Grid>

                            <Grid Grid.Column="1"
                                    Background="#273240"
                                    Margin="5,0,10,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0"
                                        Margin ="0,0,0,0"
                                        Background="#354152">
                                </Border>

                                <Border Grid.Row="1"
                                        Margin="0,5,0,0"
                                        Background="#2E3A4A">
                                    <UniformGrid Rows="2">
                                        <Border Margin="0,0,0,5"
                                                Background="#354152"/>
                                        <Border Background="#3B4758"/>
                                    </UniformGrid>
                                </Border>

                                <Border Grid.Row="2"
                                        Margin="0,5,0,0"
                                        Background="#3B4758">
                                </Border>
                            </Grid>

                            <Grid Grid.Column="2"
                                    Background="#273240"
                                    Margin="5,0,10,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="2*" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0"
                                        Margin ="0,0,0,0"
                                        Background="#2E3A4A">
                                </Border>

                                <Border Grid.Row="1"
                                        Margin="0,5,0,0"
                                        Background="#273240">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- CỘT 1 -->
                                        <Border Grid.Column="0"
                                                Margin="0,0,5,0"
                                                Background="#1F2733">

                                            <DockPanel LastChildFill="True">
                                                <Border DockPanel.Dock="Top"
                                                        Height="30"
                                                        Margin="0,0,0,5"
                                                        Background="#2E3A4A">
                                                    <TextBlock Text="Throttle"
                                                               Foreground="White"
                                                               FontSize="15"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               TextAlignment="Center"/>
                                                </Border>

                                                <Border Margin="0,0,0,5"
                                                        Background="#354152"/>
                                                <Border Background="#3B4758"/>
                                                
                                            </DockPanel>
                                        </Border>

                                        <!-- CỘT 2 -->
                                        <Border Grid.Column="1"
                                                Margin="0,0,5,0"
                                                Background="#1F2733">
                                            <DockPanel LastChildFill="True">
                                                <Border DockPanel.Dock="Top"
                                                        Height="30"
                                                        Margin="0,0,0,5"
                                                        Background="#2E3A4A">
                                                    <TextBlock Text="Brake"
                                                               Foreground="White"
                                                               FontSize="15"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               TextAlignment="Center"/>
                                                </Border>

                                                <Border Margin="0,0,0,5"
                                                        Background="#354152"/>
                                                <Border Background="#3B4758"/>
                                                
                                            </DockPanel>
                                        </Border>

                                        <!-- CỘT 3 -->
                                        <Border Grid.Column="2"
                                                Margin="0,0,0,0"
                                                Background="#1F2733">

                                            <DockPanel LastChildFill="True">
                                                <Border DockPanel.Dock="Top"
                                                        Height="30"
                                                        Margin="0,0,0,5"
                                                        Background="#2E3A4A">
                                                    <TextBlock Text="Fuel Tank"
                                                               Foreground="White"
                                                               FontSize="15"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               TextAlignment="Center"/>
                                                </Border>

                                                <Border Margin="0,0,0,5"
                                                        Background="#354152"/>
                                                <Border Background="#3B4758"/>
                                                
                                            </DockPanel>
                                        </Border>

                                    </Grid>
                                </Border>
                            </Grid>

                        </Grid>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- TAB 2 -->
            <TabItem Header="Race Summary Graph">
                <Grid Background="#1F2733">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Title -->
                        <RowDefinition Height="*"/>
                        <!-- Data -->
                    </Grid.RowDefinitions>

                    <!-- TITLE BLOCK -->
                    <Border Grid.Row="0"
                            Margin="0,0,0,0"
                            Padding="0"
                            Background="#273240"
                            BorderBrush="#374252"
                            BorderThickness="1">
                        <TextBlock Text="Race Summary Graph"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="White"/>
                    </Border>

                    <!-- DATA BLOCK -->
                    <ScrollViewer Grid.Row="1"
                                  Margin="10"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <Grid Background="#273240">
                            <!-- BUILD BLOCK TAB 2 Ở ĐÂY -->
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>